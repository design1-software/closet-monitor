cat > .gitignore << 'EOF'
# Local secrets — never commit
config.h

# Log files
*.log
overnight-*.log

# macOS
.DS_Store

# Arduino build artifacts
build/
*.hex
*.bin
*.elf
EOF
# Python
subscriber/venv/
subscriber/__pycache__/
subscriber/.env
*.pyc

# Database (regenerable from logs/MQTT)
data/*.db
data/*.db-journal

# Jupyter
.ipynb_checkpoints/
